<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title or "Rafael Zilião" }}</title>
    {% if description %}<meta name="description" content="{{ description }}">{% endif %}
    <meta property="og:title" content="{{ title or 'Rafael Zilião' }}">
    {% if description %}<meta property="og:description" content="{{ description }}">{% endif %}
    <meta property="og:type" content="website">
    <meta property="og:image" content="https://rafaelhziliao.github.io/memory-dump/assets/images/hero-banner.png">
    <meta property="og:image:width" content="1672">
    <meta property="og:image:height" content="941">
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="{{ title or 'Rafael Zilião' }}">
    {% if description %}<meta name="twitter:description" content="{{ description }}">{% endif %}
    <meta name="twitter:image" content="https://rafaelhziliao.github.io/memory-dump/assets/images/hero-banner.png">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;700&family=Poppins:wght@700;900&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="{{ '/assets/css/theme.css' | url }}">
</head>
<body>
{{ content | safe }}
</body>
</html>
